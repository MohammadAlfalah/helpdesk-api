{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            // Builds + starts Postgres (via the "dev: prepare" task), runs the API on
            // http://localhost:8090, and opens Swagger once it's listening.
            "name": "Run HelpDesk API (http://localhost:8090)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "dev: prepare",
            "program": "${workspaceFolder}/HelpDesk.Api/bin/Debug/net10.0/HelpDesk.Api.dll",
            "args": [],
            "cwd": "${workspaceFolder}/HelpDesk.Api",
            "stopAtEntry": false,
            "console": "internalConsole",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:8090"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/swagger"
            }
        }
    ]
}
