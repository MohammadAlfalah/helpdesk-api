# Copy to `.env` (git-ignored) to override docker-compose defaults.

# JWT signing key for the API (must be at least 32 bytes). A demo default is baked
# into docker-compose.yml so `docker compose up` works out of the box; set your own
# for anything beyond local play.
JWT_KEY=change-me-to-a-long-random-secret-at-least-32-bytes

# Host port the API is published on (default 8080).
API_PORT=8080
